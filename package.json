{
  "name": "os-specific-runner",
  "version": "2.2.0",
  "description": "GitHub Action that runs a different shell command per OS (Linux, macOS, Windows, AIX, FreeBSD, OpenBSD, SunOS) with configurable shells including bash, zsh, sh, pwsh, cmd, and python",
  "main": "index.js",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "build": "ncc build index.js -m"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlkidcrypto/os-specific-runner.git"
  },
  "keywords": [
    "github-action",
    "github-actions",
    "os-specific-runner",
    "os-specific-run",
    "cross-platform",
    "multi-platform",
    "platform-detection",
    "linux",
    "macos",
    "windows",
    "aix",
    "freebsd",
    "openbsd",
    "sunos",
    "bash",
    "zsh",
    "pwsh",
    "powershell",
    "shell",
    "ci",
    "cd",
    "automation"
  ],
  "author": "carlkidcrypto",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/carlkidcrypto/os-specific-runner/issues"
  },
  "homepage": "https://github.com/carlkidcrypto/os-specific-runner#readme",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@vercel/ncc": "^0.38.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-jest": "^30.3.0",
    "jest": "^30.2.0"
  },
  "jest": {
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageReporters": ["text", "lcov"]
  }
}
